# Required: token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Optional: path to SQLite database file
SQLITE_PATH=kotnost.sqlite

# Optional: bot launch retry delay in milliseconds
RETRY_DELAY_MS=10000

# Optional: reminder check interval in milliseconds
REMINDER_CHECK_INTERVAL_MS=3600000

# Optional: logging level (info | debug)
LOG_LEVEL=info

# Optional: verbose logging of Telegram updates (0 | 1)
DEBUG_UPDATES=0
